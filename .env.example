# ── Google Gemini (used for embeddings) ─────────────────────────────
GOOGLE_API_KEY=your-google-api-key-here

# ── Embedding model (local, no API needed) ──────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Groq API key (get from https://console.groq.com) ───────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── LLM model for agents ───────────────────────────────────────────
LLM_MODEL=llama-3.3-70b-versatile

# ── LLM Provider (groq, gemini, or openai) ─────────────────────────
LLM_PROVIDER=groq

# ── Chunking parameters ────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── FAISS vector-store persistence path ─────────────────────────────
VECTOR_DB_PATH=./vector_store

# ── Logging ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Optional: MLflow experiment tracking ────────────────────────────
# Uncomment and set to enable automatic run tracking.
# MLFLOW_TRACKING_URI=http://localhost:5000
